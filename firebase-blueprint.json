{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" },
        "displayName": { "type": "string" },
        "settings": { "type": "object" }
      },
      "required": ["createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    }
  }
}
